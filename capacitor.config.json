{
  "appId": "net.rbios.runcount",
  "appName": "RunCount",
  "webDir": "build",
  "ios": {
    "contentInset": "automatic",
    "packageManager": "SPM"
  },
  "android": {
    "backgroundColor": "#1a5c45"
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "launchShowDuration": 1500,
      "backgroundColor": "#1a5c45",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "LIGHT",
      "backgroundColor": "#1a5c45"
    }
  }
}
